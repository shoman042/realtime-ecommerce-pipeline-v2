.docker/
*/mysql_data/
*/kafka_data/
*/zookeeper_data/

# --- Airflow ---
# Ignore Airflow logs and database
/logs/
airflow.db
airflow.cfg
webserver_config.py

# --- IDEs & OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs & Temp Files ---
*.log
tmp/
temp/